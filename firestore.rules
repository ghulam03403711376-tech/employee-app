rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Primitives ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/employees/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.role == 'Admin';
    }

    function isManager() {
      return isSignedIn() && exists(/databases/$(database)/documents/employees/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.role == 'Manager';
    }

    function isOwner(employeeId) {
      return isSignedIn() && request.auth.uid == employeeId;
    }

    // --- Validation Blueprints ---
    function isValidEmployee(data) {
      return data.keys().hasAll(['name', 'role', 'email']) &&
             data.keys().size() <= 15 &&
             data.name is string && data.name.size() <= 100 &&
             data.role is string && data.role in ['Admin', 'Manager', 'Employee'] &&
             data.email is string && data.email.size() <= 150 &&
             data.get('phone', '') is string &&
             data.get('salaryType', 'Monthly') is string &&
             data.get('salaryAmount', 0) is number &&
             data.get('commissionPercentage', 0) is number &&
             data.get('leavePolicy', '') is string &&
             data.get('lateAllowanceMinutes', 0) is number &&
             data.get('isMealAllowanceEligible', false) is bool &&
             data.get('joinDate', '') is string &&
             data.get('isActive', true) is bool &&
             data.get('isEmailVerified', false) is bool && 
             data.get('leaveBalance', 0) is number &&
             data.get('profilePicture', '') is string;
    }

    function isValidAttendanceRecord(data) {
      return data.keys().hasAll(['employeeId', 'date', 'status']) &&
             data.keys().size() <= 12 &&
             data.employeeId is string && data.employeeId.size() <= 128 &&
             data.date is string && data.date.size() <= 50 &&
             data.status is string && data.status in ['Present', 'Absent', 'Holiday', 'Leave'] &&
             data.get('checkIn', '') is string &&
             data.get('lunchOut', '') is string &&
             data.get('lunchIn', '') is string &&
             data.get('checkOut', '') is string &&
             data.get('lateMinutes', 0) is number &&
             data.get('earlyLeaveMinutes', 0) is number &&
             data.get('isMealAllowanceGranted', false) is bool &&
             data.get('workedHours', 0) is number &&
             data.get('location', '') is string;
    }

    function isValidLeaveRequest(data) {
      return data.keys().hasAll(['employeeId', 'startDate', 'status']) &&
             data.keys().size() <= 10 &&
             data.employeeId is string && data.employeeId.size() <= 128 &&
             data.startDate is string && data.startDate.size() <= 50 &&
             data.status is string && data.status in ['Pending', 'Approved', 'Rejected'] &&
             data.get('endDate', '') is string &&
             data.get('reason', '') is string &&
             data.get('isPaid', false) is bool &&
             data.get('appliedAt', '') is string && 
             data.get('type', '') is string &&
             data.get('approvedBy', '') is string &&
             data.get('approvedAt', '') is string;
    }

    function isValidHoliday(data) {
      return data.keys().hasAll(['name', 'date']) &&
             data.keys().size() <= 4 &&
             data.name is string && data.name.size() <= 100 &&
             data.date is string && data.date.size() <= 50 &&
             data.get('isPaid', false) is bool &&
             data.get('createdAt', '') is string;
    }

    function isValidAdvance(data) {
      return data.keys().hasAll(['employeeId', 'amount', 'date']) &&
             data.keys().size() <= 5 &&
             data.employeeId is string && data.employeeId.size() <= 128 &&
             data.amount is number &&
             data.date is string && data.date.size() <= 50 &&
             data.get('status', '') is string &&
             data.get('reason', '') is string;
    }

    function isValidPayroll(data) {
      return data.keys().hasAll(['employeeId', 'month', 'finalSalary']) &&
             data.keys().size() <= 14 &&
             data.employeeId is string && data.employeeId.size() <= 128 &&
             data.month is string && data.month.size() <= 50 &&
             data.finalSalary is number &&
             data.get('periodStart', '') is string &&
             data.get('periodEnd', '') is string &&
             data.get('baseSalary', 0) is number &&
             data.get('commission', 0) is number &&
             data.get('bonus', 0) is number &&
             data.get('overtime', 0) is number &&
             data.get('mealAllowance', 0) is number &&
             data.get('deductions', 0) is number &&
             data.get('status', '') is string &&
             data.get('generatedAt', '') is string && 
             data.get('paymentMethod', '') is string;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'description', 'dueDate', 'status', 'createdAt', 'priority']) &&
             data.keys().size() <= 12 &&
             data.title is string && data.title.size() <= 100 &&
             data.description is string && data.description.size() <= 500 &&
             data.dueDate is string && data.dueDate.size() <= 50 &&
             data.status is string && data.status in ['Pending', 'Completed'] &&
             data.priority is string && data.priority in ['High', 'Medium', 'Low'] &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             data.get('employeeId', '') is string &&
             data.get('assigneeId', '') is string &&
             data.get('reminderDate', '') is string &&
             (data.get('tags', []) is list && data.get('tags', []).size() <= 10) &&
             (data.get('subtasks', []) is list && data.get('subtasks', []).size() <= 20);
    }

    // --- Collections ---

    match /employees/{employeeId} {
      allow get: if isOwner(employeeId) || isAdmin() || isManager();
      allow list: if isAdmin() || isManager() || isOwner(request.auth.uid);
      
      allow create: if isValidId(employeeId) && isValidEmployee(incoming()) && (
        isAdmin() || 
        (isOwner(employeeId) && incoming().role == 'Employee')
      );
      
      allow update: if isValidId(employeeId) && isValidEmployee(incoming()) && (
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['salaryAmount', 'salaryType', 'role', 'commissionPercentage', 'leavePolicy', 'lateAllowanceMinutes', 'isMealAllowanceEligible', 'name', 'phone', 'isActive', 'profilePicture', 'isEmailVerified', 'leaveBalance'])) ||
        (isManager() && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'isActive', 'profilePicture', 'isEmailVerified'])) ||
        (isOwner(employeeId) && incoming().diff(existing()).affectedKeys().hasOnly(['isEmailVerified', 'profilePicture', 'phone']))
      );
    }

    match /attendance/{recordId} {
      allow get: if isOwner(existing().employeeId) || isAdmin() || isManager();
      allow list: if isAdmin() || isManager() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      
      allow create: if isValidId(recordId) && isValidAttendanceRecord(incoming()) &&
                    ((isSignedIn() && incoming().employeeId == request.auth.uid) || isAdmin() || isManager());
      
      allow update: if isValidId(recordId) && isValidAttendanceRecord(incoming()) && (
        (isSignedIn() && existing().employeeId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasAny(['checkIn', 'lunchOut', 'lunchIn', 'checkOut', 'status', 'lateMinutes', 'isMealAllowanceGranted'])) ||
        isAdmin() || isManager()
      );
    }

    match /leaves/{leaveId} {
      allow get: if isOwner(existing().employeeId) || isAdmin() || isManager();
      allow list: if isAdmin() || isManager() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      
      allow create: if isValidId(leaveId) && isValidLeaveRequest(incoming()) &&
                    ((isSignedIn() && incoming().employeeId == request.auth.uid && incoming().status == 'Pending') || isAdmin() || isManager());
      
      allow update: if isValidId(leaveId) && isValidLeaveRequest(incoming()) && (
        (isAdmin() || isManager()) && incoming().diff(existing()).affectedKeys().hasAny(['status', 'isPaid', 'endDate', 'startDate', 'reason', 'type', 'approvedBy', 'approvedAt'])
      );
    }

    match /holidays/{holidayId} {
      allow get, list: if isSignedIn();
      allow create: if isValidId(holidayId) && isValidHoliday(incoming()) && isAdmin();
      allow update: if isValidId(holidayId) && isValidHoliday(incoming()) && isAdmin();
      allow delete: if isAdmin();
    }

    match /payrolls/{payrollId} {
      allow get: if isOwner(existing().employeeId) || isAdmin() || isManager();
      allow list: if isAdmin() || isManager() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      
      allow create: if isValidId(payrollId) && isValidPayroll(incoming()) && (isAdmin() || isManager());
      allow update: if isValidId(payrollId) && isValidPayroll(incoming()) && (isAdmin() || isManager());
      allow delete: if isAdmin() || isManager();
    }

    match /advances/{advanceId} {
      allow get: if isOwner(existing().employeeId) || isAdmin() || isManager();
      allow list: if isAdmin() || isManager() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      
      allow create: if isValidId(advanceId) && isValidAdvance(incoming()) && (isAdmin() || isManager());
      allow update: if isValidId(advanceId) && isValidAdvance(incoming()) && (isAdmin() || isManager());
      allow delete: if isAdmin() || isManager();
    }

    match /tasks/{taskId} {
      allow get: if isOwner(existing().employeeId) || isOwner(existing().assigneeId) || isAdmin() || isManager();
      allow list: if isAdmin() || isManager() || (isSignedIn() && (resource.data.employeeId == request.auth.uid || resource.data.assigneeId == request.auth.uid)) || isSignedIn();
      allow create: if isValidId(taskId) && isValidTask(incoming()) && isSignedIn();
      allow update: if isValidId(taskId) && isValidTask(incoming()) && (
        isAdmin() || isManager() || isOwner(existing().employeeId) || isOwner(existing().assigneeId) || isOwner(existing().employeeId) == false
      );
      allow delete: if isAdmin() || isManager() || isOwner(existing().employeeId) || isOwner(existing().assigneeId);
    }
  }
}
