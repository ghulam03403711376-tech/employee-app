{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "System user with role and pay details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Manager", "Employee"] },
        "salaryType": { "type": "string", "enum": ["Daily", "Weekly", "Monthly"] },
        "salaryAmount": { "type": "number" },
        "commissionPercentage": { "type": "number" },
        "leavePolicy": { "type": "string" },
        "lateAllowanceMinutes": { "type": "number" },
        "isMealAllowanceEligible": { "type": "boolean" },
        "joinDate": { "type": "string" },
        "isActive": { "type": "boolean" },
        "email": { "type": "string" }
      },
      "required": ["name", "role", "email"]
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "description": "Daily clock-in/out record",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "date": { "type": "string" },
        "checkIn": { "type": "string" },
        "lunchOut": { "type": "string" },
        "lunchIn": { "type": "string" },
        "checkOut": { "type": "string" },
        "status": { "type": "string", "enum": ["Present", "Absent", "Holiday", "Leave"] },
        "lateMinutes": { "type": "number" },
        "earlyLeaveMinutes": { "type": "number" },
        "isMealAllowanceGranted": { "type": "boolean" },
        "workedHours": { "type": "number" }
      },
      "required": ["employeeId", "date", "status"]
    },
    "LeaveRequest": {
      "title": "Leave Request",
      "description": "Request for time off",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "isPaid": { "type": "boolean" },
        "appliedAt": { "type": "string" }
      },
      "required": ["employeeId", "startDate", "status"]
    },
    "Holiday": {
      "title": "Holiday",
      "description": "Official company holidays",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string" },
        "isPaid": { "type": "boolean" }
      },
      "required": ["name", "date"]
    },
    "Advance": {
      "title": "Salary Advance",
      "description": "Cash advance given to employee",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["employeeId", "amount", "date"]
    },
    "Payroll": {
      "title": "Payroll Record",
      "description": "Final salary calculation for a period",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "month": { "type": "string" },
        "periodStart": { "type": "string" },
        "periodEnd": { "type": "string" },
        "baseSalary": { "type": "number" },
        "commission": { "type": "number" },
        "bonus": { "type": "number" },
        "overtime": { "type": "number" },
        "mealAllowance": { "type": "number" },
        "deductions": { "type": "number" },
        "finalSalary": { "type": "number" },
        "status": { "type": "string" },
        "generatedAt": { "type": "string" }
      },
      "required": ["employeeId", "month", "finalSalary"]
    }
  },
  "firestore": {
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Registered employees"
    },
    "/attendance": {
      "schema": "AttendanceRecord",
      "description": "Flattened attendance logs"
    },
    "/leaves": {
      "schema": "LeaveRequest",
      "description": "Leave submissions"
    },
    "/holidays": {
      "schema": "Holiday",
      "description": "Public and store holidays"
    },
    "/advances": {
      "schema": "Advance",
      "description": "Advance history"
    },
    "/payrolls": {
      "schema": "Payroll",
      "description": "Generated pay slips"
    }
  }
}
